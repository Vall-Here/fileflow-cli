{
  "name": "fileflow-cli",
  "version": "1.0.1",
  "description": "A smart CLI tool to organize files, bulk rename, convert data formats, and automate repetitive file tasks.",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/my-package.git"
  },
  "main": "src/index.js",
  "bin": {
    "fileflow": "./bin/fileflow.js"
  },
  "scripts": {
    "start": "node bin/fileflow.js",
    "dev": "node --watch bin/fileflow.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "jest": {
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "keywords": [
    "cli",
    "file-organizer",
    "bulk-rename",
    "data-converter",
    "automation"
  ],
  "author": "Ahmad Noval <ahmadnoval.muhyiddin@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "papaparse": "^5.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mock-fs": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
